# -*- coding: utf-8 -*-
"""
+==============================================+
|           KАЛЬКУЛЯТОР v1.1                  |
|   Сложение · Вычитание · Умножение          |
|   Деление · Степень · Квадратный корень     |
|   [+] История вычислений (h)                 |
+==============================================+
"""

import math
import sys
import io
from collections import deque

# Принудительно включаем UTF-8 для вывода в Windows-консоли
if sys.platform == "win32":
    sys.stdout = io.TextIOWrapper(
        sys.stdout.buffer, encoding="utf-8", errors="replace"
    )


# --- История вычислений --------------------------------------------------

история = deque(maxlen=10)  # Хранит последние 10 операций


def добавить_в_историю(запись):
    """Добавляет запись в историю вычислений."""
    история.append(запись)


def показать_историю():
    """Выводит историю последних вычислений."""
    print()
    print("  +----------------------------------------------+")
    print("  |  ИСТОРИЯ ВЫЧИСЛЕНИЙ (последние 10):          |")
    print("  +----------------------------------------------+")
    if not история:
        print("  |  (пусто)                                     |")
    else:
        for i, запись in enumerate(история, 1):
            print(f"  |  {i:>2}. {запись:<43} |")
    print("  +----------------------------------------------+")
    print()


# --- Математические функции ----------------------------------------------


def сложение(a, b):
    """Возвращает сумму двух чисел."""
    return a + b


def вычитание(a, b):
    """Возвращает разность двух чисел."""
    return a - b


def умножение(a, b):
    """Возвращает произведение двух чисел."""
    return a * b


def деление(a, b):
    """Возвращает частное от деления a на b."""
    if b == 0:
        raise ZeroDivisionError("Деление на ноль невозможно.")
    return a / b


def степень(a, b):
    """Возвращает a, возведённое в степень b."""
    return a ** b


def квадратный_корень(a):
    """Возвращает квадратный корень из числа a."""
    if a < 0:
        raise ValueError(
            "Квадратный корень из отрицательного числа "
            "не извлекается (в вещественных числах)."
        )
    return math.sqrt(a)


# --- Вспомогательные функции --------------------------------------------

def ввод_числа(подсказка):
    """Запрашивает у пользователя число с обработкой ошибок ввода."""
    while True:
        try:
            значение = input(подсказка).strip()
            if значение == "":
                print("  [!] Пустой ввод. Пожалуйста, введите число.")
                continue
            return float(значение)
        except ValueError:
            print("  [!] Это не число. Введите корректное число "
                  "(например, 5 или 3.14).")
        except KeyboardInterrupt:
            print("\n\n  До свидания!")
            sys.exit(0)


def пауза():
    """Ожидает нажатия Enter для продолжения."""
    input("\n  Нажмите Enter, чтобы продолжить...")


def очистить_экран():
    """Очищает консоль (Windows / Unix)."""
    import os
    os.system("cls" if os.name == "nt" else "clear")


def заголовок():
    """Выводит красивый заголовок."""
    print()
    print("  +==============================================+")
    print("  |            >> KАЛЬКУЛЯТОР v1.1 <<            |")
    print("  +==============================================+")
    print()


def меню():
    """Выводит меню операций и возвращает выбор пользователя."""
    print("  +----------------------------------------------+")
    print("  |  Выберите операцию:                          |")
    print("  |                                              |")
    print("  |   1  [+]  Сложение                           |")
    print("  |   2  [-]  Вычитание                          |")
    print("  |   3  [*]  Умножение                          |")
    print("  |   4  [/]  Деление                            |")
    print("  |   5  [^]  Возведение в степень  (a^b)        |")
    print("  |   6  [V]  Квадратный корень     (Va)         |")
    print("  |                                              |")
    print("  |   h  [H]  История вычислений                 |")
    print("  |   0  [X]  Выход                              |")
    print("  +----------------------------------------------+")
    print()

    while True:
        try:
            выбор = input("  Ваш выбор (0-6 или h): ").strip().lower()
            if выбор in ("0", "1", "2", "3", "4", "5", "6", "h"):
                return выбор
            else:
                print("  [!] Пожалуйста, введите число от 0 до 6 или h.")
        except KeyboardInterrupt:
            print("\n\n  До свидания!")
            sys.exit(0)


def показать_результат(операция, a, b, результат):
    """Красиво выводит результат бинарной операции."""
    print()
    print("  +----------------------------------------------+")
    print(f"  |  {операция:<44} |")
    print(f"  |  {a}  и  {b:<36} |")
    print(f"  |                                              |")
    print(f"  |  >> Результат:  {результат:<28} |")
    print("  +----------------------------------------------+")
    print()


def показать_результат_унарный(операция, a, результат):
    """Красиво выводит результат унарной операции."""
    print()
    print("  +----------------------------------------------+")
    print(f"  |  {операция:<44} |")
    print(f"  |  Для числа:  {a:<34} |")
    print(f"  |                                              |")
    print(f"  |  >> Результат:  {результат:<28} |")
    print("  +----------------------------------------------+")
    print()


# --- Главный цикл --------------------------------------------------------

def main():
    """Главная функция калькулятора."""
    while True:
        очистить_экран()
        заголовок()
        выбор = меню()

        if выбор == "0":
            print()
            print("  +----------------------------------------------+")
            print("  |        Спасибо за использование!             |")
            print("  |             До свидания!                     |")
            print("  +----------------------------------------------+")
            print()
            sys.exit(0)

        if выбор == "h":
            показать_историю()
            пауза()
            continue

        try:
            if выбор == "1":
                a = ввод_числа("  Введите первое число: ")
                b = ввод_числа("  Введите второе число: ")
                результат = сложение(a, b)
                показать_результат("Сложение (+)", a, b, результат)
                добавить_в_историю(f"{a} + {b} = {результат}")

            elif выбор == "2":
                a = ввод_числа("  Введите уменьшаемое: ")
                b = ввод_числа("  Введите вычитаемое: ")
                результат = вычитание(a, b)
                показать_результат("Вычитание (-)", a, b, результат)
                добавить_в_историю(f"{a} - {b} = {результат}")

            elif выбор == "3":
                a = ввод_числа("  Введите первый множитель: ")
                b = ввод_числа("  Введите второй множитель: ")
                результат = умножение(a, b)
                показать_результат("Умножение (*)", a, b, результат)
                добавить_в_историю(f"{a} * {b} = {результат}")

            elif выбор == "4":
                a = ввод_числа("  Введите делимое: ")
                b = ввод_числа("  Введите делитель: ")
                результат = деление(a, b)
                показать_результат("Деление (/)", a, b, результат)
                добавить_в_историю(f"{a} / {b} = {результат}")

            elif выбор == "5":
                a = ввод_числа("  Введите основание: ")
                b = ввод_числа("  Введите показатель степени: ")
                результат = степень(a, b)
                показать_результат("Возведение в степень (^)", a, b, результат)
                добавить_в_историю(f"{a} ^ {b} = {результат}")

            elif выбор == "6":
                a = ввод_числа("  Введите число: ")
                результат = квадратный_корень(a)
                показать_результат_унарный("Квадратный корень (V)", a, результат)
                добавить_в_историю(f"sqrt({a}) = {результат}")

        except ZeroDivisionError as e:
            print()
            print(f"  [!] Ошибка: {e}")
            print()
        except ValueError as e:
            print()
            print(f"  [!] Ошибка: {e}")
            print()
        except OverflowError:
            print()
            print("  [!] Ошибка: Слишком большое число - переполнение.")
            print()
        except Exception as e:
            print()
            print(f"  [!] Непредвиденная ошибка: {e}")
            print()

        пауза()


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n  До свидания!")
        sys.exit(0)
